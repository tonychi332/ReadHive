# PostgreSQL connection string (e.g. from a free Neon or Supabase project)
DATABASE_URL="postgresql://user:password@localhost:5432/readhive?schema=public"

# Auth.js — generate with `npx auth secret` or `openssl rand -base64 32`
AUTH_SECRET=""

# Optional seed credentials (defaults to "ChangeMe123!" if not set)
SEED_ADMIN_PASSWORD=""
SEED_AUTHOR_PASSWORD=""

# S3-compatible storage for cover/ebook uploads (e.g. Cloudflare R2, AWS S3).
# Leave unset to disable uploads — the rest of the app still works.
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME=""
S3_PUBLIC_URL_BASE=""

# Paystack (architecture only — purchases are simulated until these are wired up)
PAYSTACK_SECRET_KEY=""
PAYSTACK_PUBLIC_KEY=""
